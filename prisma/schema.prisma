generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  preferences   Preferences?
  watchlist     WatchlistItem[]
  savedSearches SavedSearch[]
  recommendationHistory RecommendationHistory[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username    String?  @unique
  bio         String?  @db.Text
  country     String?  @default("US")
  timezone    String?  @default("UTC")
  language    String?  @default("en")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Preferences {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredGenres     String[] @default([]) @map("preferred_genres")
  preferredPlatforms  String[] @default([]) @map("preferred_platforms")
  contentRatings      String[] @default([]) @map("content_ratings")
  emailNotifications  Boolean  @default(true) @map("email_notifications")
  darkMode            Boolean  @default(true) @map("dark_mode")
  autoplayTrailers    Boolean  @default(false) @map("autoplay_trailers")
  language            String   @default("en")
  region              String   @default("US")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("preferences")
}

model WatchlistItem {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String   @map("content_id")
  contentType String   @default("movie") @map("content_type")
  title       String
  posterUrl   String?  @map("poster_url")
  platform    String?
  genre       String?
  rating      String?
  year        Int?
  notes       String?  @db.Text
  watched     Boolean  @default(false)
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, contentId])
  @@index([userId])
  @@map("watchlist_items")
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  query       String   @db.Text
  filters     Json?    @default("{}")
  country     String?  @default("US")
  mood        String?
  genres      String[] @default([])
  resultCount Int?     @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("saved_searches")
}

model RecommendationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt      String   @db.Text
  mood        String?
  genres      String[] @default([])
  country     String?  @default("US")
  response    Json?
  confidence  Float?   @default(0)
  platforms   String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("recommendation_history")
}

model TrendingContent {
  id          String   @id @default(cuid())
  contentId   String   @unique @map("content_id")
  contentType String   @default("movie") @map("content_type")
  title       String
  overview    String?  @db.Text
  posterUrl   String?  @map("poster_url")
  backdropUrl String?  @map("backdrop_url")
  genre       String[] @default([])
  platform    String[] @default([])
  rating      String?
  year        Int?
  country     String   @default("US")
  score       Float    @default(0)
  trendingAt  DateTime @default(now()) @map("trending_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([country, score])
  @@index([trendingAt])
  @@map("trending_content")
}
